# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenAI (Cynthia — staff, web/portal/WhatsApp, and phone)
OPENAI_API_KEY=sk-your-key-here

# WhatsApp — live transport is WhatsApp Web.js (QR in Integrations). Path B Meta is cold forever.
# Do NOT set WHATSAPP_META_ENABLED=true in production. Leave Meta secrets blank.
WHATSAPP_META_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=sync2dine_verify
META_APP_SECRET=

# Voice Telephony (Cynthia phone AI — Vapi only, no sip-bridge rollback)
# Soho66 credentials below feed the Vapi SIP trunk; do not set VOICE_PROVIDER to soho66/local_realtime.
TELEPHONY_PROVIDER=vapi
VOICE_PROVIDER=vapi
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
VAPI_REGION=eu
VAPI_WEBHOOK_BASE_URL=
VAPI_SERVER_SECRET=
VAPI_PHONE_NUMBER_ID=
VAPI_SIP_CREDENTIAL_ID=
VAPI_ASSISTANT_ID=
VAPI_ELEVENLABS_VOICE_ID=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
VAPI_LLM_MODEL=gpt-4o
SOHO66_SIP_BRIDGE_URL=http://127.0.0.1:3100
SOHO66_SIP_USERNAME=
SOHO66_SIP_PASSWORD=
# Prefer SBC for NAT / two-way audio (Soho66 recommendation)
SOHO66_SIP_DOMAIN=sbc.soho66.co.uk
SOHO66_FROM_NUMBER=
VOICE_TRANSFER_NUMBER=
# Optional department transfers (Judie/restaurant). Leave unset on Sally sales — AI-staffed, no human dial.
# VOICE_TRANSFER_SALES=
# VOICE_TRANSFER_PROJECTS=
# VOICE_TRANSFER_RECRUITMENT=
# VOICE_TRANSFER_ACCOUNTS=
VOICE_WEBHOOK_VERIFY_TOKEN=sync2dine_voice_verify
VOICE_AFTER_HOURS=0
VOICE_BUSINESS_HOURS_START=09:00
VOICE_BUSINESS_HOURS_END=17:30
# realtime = OpenAI Realtime speech-to-speech (default); pipeline = Whisper→GPT→TTS fallback
VOICE_MODE=realtime
REALTIME_MODEL=gpt-realtime
# Female British-leaning Realtime voice (coral); accent also forced in session instructions
REALTIME_VOICE=coral
WEBHOOK_BASE_URL=
APP_BASE_URL=https://app.sync2dine.io
SIP_BRIDGE_PUBLIC_IP=
SIP_BRIDGE_RTP_PORT_BASE=10006

# Twilio SMS (Sally sendSalesFollowUp + POST /api/sms/send). Voice AI stays on Vapi.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Alias accepted by sendTwilioSms if TWILIO_FROM_NUMBER is empty:
# TWILIO_PHONE_NUMBER=

# Sally sales / demo line — inbound on these numbers always gets Sally (not Judie restaurant).
# Prefer the same number as TWILIO_FROM_NUMBER when Voice+SMS share one DID (import into Vapi).
SALLY_DEMO_PHONE=
# Comma/semicolon-separated extra DIDs treated as Sally inbound (E.164 or UK national).
SALLY_INBOUND_NUMBERS=
# Website link included in Sally SMS/email follow-ups
SALLY_WEBSITE_URL=https://sync2dine.io
SALLY_LAUNCH_ACTIVE=1
# Set to 1 only if you intentionally want Sally warm-transfer (default: blocked — AI-staffed line).
# SALLY_ALLOW_TRANSFER=0
# SALLY_DEMO_VIDEO_URL=
# SALLY_VOICEMAIL_MESSAGE=

# Chatterbox TTS
CHATTERBOX_BASE_URL=
CHATTERBOX_API_KEY=
CHATTERBOX_TTS_PATH=/tts

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=info@sync2dine.io
SMTP_FROM_NAME=Sync2Dine
SMTP_SECURE=true

# Phone concurrency — max simultaneous live calls (inbound + outbound) per org
MAX_CONCURRENT_CALLS_PER_ORG=5
OUTBOUND_POLL_MS=15000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SYNC2DINE_PLATFORM=
STRIPE_PRICE_SYNC2DINE_KIOSK=

# Price Research
PRICE_RESEARCH_PROVIDER=openai_web
PRICE_RESEARCH_API_KEY=
PRICE_RESEARCH_REGION=UK

# Platform
PORT=3001
AUTH_ENFORCED=false
PLATFORM_OWNER_EMAIL=owner@sync2dine.io
PLATFORM_OWNER_PASSWORD=platform123
ORG_ENCRYPTION_KEY=
JWT_SECRET=
SIGNING_SALT=
INTEGRATIONS_MOCK_MODE=true
BUILDER_INBOUND_ORCHESTRATE=false

# Legacy data import path (frontend repo)
LEGACY_DATA_PATH=../sync2dine-frontend/server/data
