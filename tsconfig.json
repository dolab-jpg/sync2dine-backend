{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true
  },
  "include": ["server/**/*", "shared/**/*"],
  "exclude": [
    "node_modules",
    "supabase/functions",
    "server/_quarantine/**",
    "scripts/**",
    "server/_repair-*.mts"
  ]
}
