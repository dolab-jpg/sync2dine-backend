# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenAI (TradePro AI + Cyrus + Aria phone agent)
OPENAI_API_KEY=sk-your-key-here

# WhatsApp Business (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=tradepro_verify
META_APP_SECRET=

# Voice Telephony (Aria AI phone agent)
# Use soho66 + local bridge: npm run sip-bridge:dev (port 3100)
# Prefer soho66 for local bridge, or leave as soho66 and set VOICE_PROVIDER=vapi
TELEPHONY_PROVIDER=soho66
# Managed phone AI path (recommended). local_realtime / soho66 = home SIP bridge rollback
VOICE_PROVIDER=vapi
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
VAPI_REGION=eu
VAPI_WEBHOOK_BASE_URL=
VAPI_SERVER_SECRET=
VAPI_PHONE_NUMBER_ID=
VAPI_SIP_CREDENTIAL_ID=
VAPI_ASSISTANT_ID=
VAPI_ELEVENLABS_VOICE_ID=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
VAPI_LLM_MODEL=gpt-4o
SOHO66_SIP_BRIDGE_URL=http://127.0.0.1:3100
SOHO66_SIP_USERNAME=
SOHO66_SIP_PASSWORD=
# Prefer SBC for NAT / two-way audio (Soho66 recommendation)
SOHO66_SIP_DOMAIN=sbc.soho66.co.uk
SOHO66_FROM_NUMBER=
VOICE_TRANSFER_NUMBER=
VOICE_WEBHOOK_VERIFY_TOKEN=tradepro_voice_verify
VOICE_AFTER_HOURS=0
VOICE_BUSINESS_HOURS_START=09:00
VOICE_BUSINESS_HOURS_END=17:30
# realtime = OpenAI Realtime speech-to-speech (default); pipeline = Whisper→GPT→TTS fallback
VOICE_MODE=realtime
REALTIME_MODEL=gpt-realtime
# Female British-leaning Realtime voice (coral); accent also forced in session instructions
REALTIME_VOICE=coral
WEBHOOK_BASE_URL=
APP_BASE_URL=http://localhost:5174
SIP_BRIDGE_PUBLIC_IP=
SIP_BRIDGE_RTP_PORT_BASE=10006

# Chatterbox TTS
CHATTERBOX_BASE_URL=
CHATTERBOX_API_KEY=
CHATTERBOX_TTS_PATH=/tts

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=TradePro
SMTP_SECURE=true

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# Price Research
PRICE_RESEARCH_PROVIDER=openai_web
PRICE_RESEARCH_API_KEY=
PRICE_RESEARCH_REGION=UK

# Platform
PORT=3001
AUTH_ENFORCED=false
PLATFORM_OWNER_EMAIL=owner@tradepro.com
PLATFORM_OWNER_PASSWORD=platform123
ORG_ENCRYPTION_KEY=
JWT_SECRET=
SIGNING_SALT=
INTEGRATIONS_MOCK_MODE=true
BUILDER_INBOUND_ORCHESTRATE=false

# Legacy data import path (frontend repo)
LEGACY_DATA_PATH=../Bathroom Sales Estimation Platform/server/data
