# Platform
PORT=3001
AUTH_ENFORCED=false
PLATFORM_OWNER_EMAIL=owner@tradepro.com
PLATFORM_OWNER_PASSWORD=platform123
ORG_ENCRYPTION_KEY=
JWT_SECRET=
SIGNING_SALT=
